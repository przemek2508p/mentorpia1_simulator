<?xml version="1.0" ?>
<robot name="ack" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Materials -->
  <xacro:include filename="$(find mentorpia1_simulator)/urdf/materials.xacro" />

  <!-- Base Link -->
  <link name="base_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.00186669751054189 3.0253386351986E-05 -0.00605296088229322"/>
      <mass value="0.0961047465616957"/>
      <inertia ixx="8.55867486364231E-05" ixy="3.41346959938296E-08" ixz="1.64755227278164E-05" iyy="0.000277248181555496" iyz="-2.95282759133104E-08" izz="0.000344246448853775"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/base_link.STL"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- Base Footprint -->
  <link name="base_footprint"/>
  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
  </joint>

  <!-- Back Axle and Wheels -->
  <link name="back_axle"/>
  <joint name="base_to_back_axle" type="fixed">
    <parent link="base_link"/>
    <child link="back_axle"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="wheel_lb_Link">
    <inertial>
      <origin rpy="0 0 0" xyz="1.62806317080544E-06 -0.00317716794378092 -1.54238045318306E-06"/>
      <mass value="0.0271078161230754"/>
      <inertia ixx="1.01056035703468E-05" ixy="4.60479373806495E-11" ixz="7.43896782806142E-10" iyy="1.67990600599721E-05" iyz="-5.763890541079E-11" izz="1.01072652738793E-05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/wheel_lb_Link.STL"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/wheel_lb_Link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="wheel_lb_Joint" type="continuous">
    <origin rpy="0 0 0" xyz="-0.07 0.07 -0.03"/>
    <parent link="back_axle"/>
    <child link="wheel_lb_Link"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="wheel_rb_Link">
    <inertial>
      <origin rpy="0 0 0" xyz="-1.50804700475154E-06 0.00317707027691583 1.18963606317302E-06"/>
      <mass value="0.0271078005024283"/>
      <inertia ixx="1.01044417409685E-05" ixy="-5.83069005452564E-11" ixz="-7.56886841840775E-11" iyy="1.67993271276785E-05" iyz="6.31638424138502E-11" izz="1.01087182681654E-05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/wheel_rb_Link.STL"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/wheel_rb_Link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="wheel_rb_Joint" type="continuous">
    <origin rpy="0 0 0" xyz="-0.07 -0.07 -0.03"/>
    <parent link="back_axle"/>
    <child link="wheel_rb_Link"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Front Axle and Steering -->
  <link name="front_axle">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="steering_wheel_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_axle"/>
    <origin xyz="0.07 0 -0.03" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="1" lower="-0.4" upper="0.4"/>
  </joint>

  <link name="left_steering_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="left_steering_joint" type="revolute">
    <parent link="front_axle"/>
    <child link="left_steering_link"/>
    <origin xyz="0 0.07 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="1" lower="-0.4" upper="0.4"/>
  </joint>

  <link name="right_steering_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="right_steering_joint" type="revolute">
    <parent link="front_axle"/>
    <child link="right_steering_link"/>
    <origin xyz="0 -0.07 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="1" lower="-0.4" upper="0.4"/>
  </joint>

  <link name="wheel_lf_Link">
    <inertial>
      <origin rpy="0 0 0" xyz="1.65897579444685E-06 -0.00270913022688685 -1.5546673051009E-06"/>
      <mass value="0.0252873083503169"/>
      <inertia ixx="1.00371783485335E-05" ixy="4.93900109379125E-11" ixz="7.42104604492639E-10" iyy="1.67620175120314E-05" iyz="-5.47583950457701E-11" izz="1.00370342405297E-05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/wheel_lf_Link.STL"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/wheel_lf_Link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="wheel_lf_Joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="left_steering_link"/>
    <child link="wheel_lf_Link"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="wheel_rf_Link">
    <inertial>
      <origin rpy="0 0 0" xyz="-1.48986965733955E-06 0.0027090575018239 1.16299057125596E-06"/>
      <mass value="0.0252873548617242"/>
      <inertia ixx="1.00360241846408E-05" ixy="-5.83065201444192E-11" ixz="-8.3023958781985E-11" iyy="1.67622954977732E-05" iyz="6.31638512668579E-11" izz="1.00384960556047E-05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/wheel_rf_Link.STL"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/wheel_rf_Link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="wheel_rf_Joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="right_steering_link"/>
    <child link="wheel_rf_Link"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Lidar -->
  <link name="lidar_frame">
    <inertial>
      <origin rpy="0 0 0" xyz="8.65086433231368E-05 9.02624784523964E-05 -0.0183546134614858"/>
      <mass value="0.0405423044068563"/>
      <inertia ixx="4.98470776877503E-06" ixy="-1.54076264166869E-07" ixz="2.05182706824286E-09" iyy="5.03926730822203E-06" iyz="1.1006285118993E-08" izz="8.25645669548359E-06"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/lidar_Link.STL"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/lidar_Link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="lidar_Joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.0096019 -8.533E-05 0.092501"/>
    <parent link="base_link"/>
    <child link="lidar_frame"/>
  </joint>

  <gazebo reference="lidar_frame">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <update_rate>10</update_rate>
      <topic>lidar</topic>
      <gz_frame_id>lidar_frame</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- Depth Camera -->
  <link name="depth_cam">
    <inertial>
      <origin rpy="0 0 0" xyz="0.0023402290651429 0.00113784597946548 -0.0102127064032341"/>
      <mass value="0.0270474748429678"/>
      <inertia ixx="1.43718505822118E-05" ixy="1.24779382573379E-07" ixz="1.29836477956744E-08" iyy="1.65912768209848E-06" iyz="2.28291478579102E-08" izz="1.45615925510082E-05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/cam_Link.STL"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://mentorpia1_simulator/meshes/acker/cam_Link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="cam_Joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.064015 -0.00013463 0.051155"/>
    <parent link="base_link"/>
    <child link="depth_cam"/>
  </joint>

  <gazebo reference="depth_cam">
    <sensor name="camera" type="camera">
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>camera</topic>
    </sensor>
  </gazebo>

  <!-- Include IMU -->
  <xacro:include filename="$(find mentorpia1_simulator)/urdf/imu.urdf.xacro"/>

  <!-- Gazebo Plugins -->
  <gazebo>
    <plugin
      filename="ignition-gazebo-ackermann-steering-system"
      name="ignition::gazebo::systems::AckermannSteering">
      <left_joint>wheel_lb_Joint</left_joint>
      <right_joint>wheel_rb_Joint</right_joint>
      <steering_joint>steering_wheel_joint</steering_joint>
      <left_steering_joint>left_steering_joint</left_steering_joint>
      <right_steering_joint>right_steering_joint</right_steering_joint>
      <left_rear_wheel_joint>wheel_lb_Joint</left_rear_wheel_joint>
      <right_rear_wheel_joint>wheel_rb_Joint</right_rear_wheel_joint>
      <left_front_wheel_joint>wheel_lf_Joint</left_front_wheel_joint>
      <right_front_wheel_joint>wheel_rf_Joint</right_front_wheel_joint>
      
      <wheel_separation>0.14</wheel_separation>
      <wheelbase>0.14</wheelbase>
      <wheel_radius>0.035</wheel_radius>
      
      <min_steering_angle>-0.4</min_steering_angle>
      <max_steering_angle>0.4</max_steering_angle>
      
      <topic>/cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>

    <plugin
      filename="ignition-gazebo-joint-state-publisher-system"
      name="ignition::gazebo::systems::JointStatePublisher">
    </plugin>

    <plugin
      filename="ignition-gazebo-imu-system"
      name="ignition::gazebo::systems::Imu">
    </plugin>
  </gazebo>

</robot>